import java.util.*;
import java.util.stream.*;
import java.util.function.Function;

public class Main {

    public static void main(String[] args) {

        String s = "dheena";

        String ans =
                Arrays.stream(s.split(""))
                        .collect(Collectors.groupingBy(
                                Function.identity(),
                                LinkedHashMap::new,
                                Collectors.counting()))
                        .entrySet()
                        .stream()
                        .filter(e -> e.getValue() == 1)
                        .map(e -> e.getKey())
                        .findFirst()
                        .get();

        System.out.println(ans);
    }
}
